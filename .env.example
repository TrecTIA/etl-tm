# ──────────────────────────────────────────────────────────────────────────────
# ETL HCMS v2 — Environment Variables
# Salin ke .env: copy .env.example .env  (Windows)
#                cp .env.example .env    (Linux/Mac)
# ──────────────────────────────────────────────────────────────────────────────

# ── Supabase Storage (untuk download file Excel yang diupload Angular) ─────────
SUPABASE_URL=https://trec-api.triputra-group.com
# Gunakan service_role key (Supabase Dashboard → Settings → API → service_role)
SUPABASE_SERVICE_KEY=your_service_role_key_here

# ── PostgreSQL target (tujuan hasil ETL) ──────────────────────────────────────
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://user_name:password@url:5432/db_nameZ

# ── CORS (URL frontend Angular) ───────────────────────────────────────────────
FRONTEND_URL=http://localhost:4200
